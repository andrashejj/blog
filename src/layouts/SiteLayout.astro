---
import { Rss } from "@lucide/astro";
import "../styles/global.css";
import { buildSeo } from "../lib/seo";
import { site } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: "website" | "article";
}

const { title, description, path, image, type = "website" } = Astro.props;

const seo = buildSeo({ title, description, path, image });

const year = new Date().getFullYear();
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{seo.title}</title>
    <meta name='description' content={seo.description} />
    <meta name='theme-color' content='#f1e6cf' />
    <link rel='canonical' href={seo.canonicalUrl} />
    <meta property='og:type' content={type} />
    <meta property='og:title' content={seo.title} />
    <meta property='og:description' content={seo.description} />
    <meta property='og:url' content={seo.canonicalUrl} />
    <meta property='og:image' content={seo.image} />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={seo.title} />
    <meta name='twitter:description' content={seo.description} />
    <meta name='twitter:image' content={seo.image} />
    <link rel='shortcut icon' href='/favicon.ico' />
    <link rel='manifest' href='/manifest.json' />
    <link
      rel='alternate'
      type='application/rss+xml'
      title={`${site.name} – RSS feed`}
      href='/rss.xml'
    />
  </head>
  <body>
    <div class='grid min-h-dvh grid-rows-[auto_1fr_auto]'>
      <header class='reveal reveal-1 sticky top-0 z-20 border-b border-rule bg-paper/85 backdrop-blur-[6px]'>
        <div class='mx-auto flex w-[min(100%-2rem,1120px)] items-center justify-between py-4'>
          <a href='/' class='no-rule group flex items-baseline gap-3' aria-label={site.name}>
            <span
              class='font-display text-2xl leading-none text-ink'
              style='font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144; font-weight: 600;'
            >A<span class='italic text-terracotta'>·</span>H</span>
            <span class='hidden font-mono text-[0.65rem] uppercase tracking-[0.3em] text-muted sm:inline'>Andras Hejj · Field Notes</span>
          </a>
          <nav class='flex items-center gap-6 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-ink-soft'>
            <a class='no-rule transition hover:text-terracotta' href='/blog'>Blog</a>
            <a class='no-rule transition hover:text-terracotta' href='/about'>About</a>
            <a
              class='no-rule inline-flex items-center gap-1.5 transition hover:text-terracotta'
              href='/subscribe'
              aria-label='Subscribe'
              title='Subscribe'
            >
              <Rss size={14} />
              <span class='hidden sm:inline'>RSS</span>
            </a>
          </nav>
        </div>
      </header>

      <main class='reveal reveal-2 mx-auto w-[min(100%-2rem,1120px)] py-12 md:py-16'>
        <slot />
      </main>

      <footer class='border-t border-rule bg-paper-deep/40'>
        <div class='mx-auto w-[min(100%-2rem,1120px)] py-8'>
          <div class='rule-horizontal mb-6'></div>
          <div class='flex flex-col items-start justify-between gap-4 text-ink-soft md:flex-row md:items-center'>
            <div class='flex items-baseline gap-3'>
              <span class='font-display text-lg' style='font-variation-settings: "SOFT" 100, "WONK" 1;'>
                © {year}
              </span>
              <span class='font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted'>
                Budapest · Zürich · Mauritius
              </span>
            </div>
            <div class='flex items-center gap-5 font-mono text-[0.72rem] uppercase tracking-[0.22em]'>
              <a href={site.social.github} target='_blank' rel='noreferrer' class='no-rule hover:text-terracotta'>GitHub</a>
              <a href={site.social.linkedin} target='_blank' rel='noreferrer' class='no-rule hover:text-terracotta'>LinkedIn</a>
              <a href={site.social.x} target='_blank' rel='noreferrer' class='no-rule hover:text-terracotta'>X</a>
              <a
                href='/rss.xml'
                class='no-rule inline-flex items-center gap-1.5 hover:text-terracotta'
                aria-label='RSS feed'
                title='RSS feed'
              >
                <Rss size={13} />
                RSS
              </a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
