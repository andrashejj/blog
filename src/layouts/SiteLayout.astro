---
import { Rss } from "@lucide/astro";
import "../styles/global.css";
import { buildSeo } from "../lib/seo";
import { site } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: "website" | "article";
}

const { title, description, path, image, type = "website" } = Astro.props;

const seo = buildSeo({ title, description, path, image });

const year = new Date().getFullYear();
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{seo.title}</title>
    <meta name='description' content={seo.description} />
    <meta name='theme-color' content='#f1e6cf' />
    <link rel='canonical' href={seo.canonicalUrl} />
    <meta property='og:type' content={type} />
    <meta property='og:title' content={seo.title} />
    <meta property='og:description' content={seo.description} />
    <meta property='og:url' content={seo.canonicalUrl} />
    <meta property='og:image' content={seo.image} />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={seo.title} />
    <meta name='twitter:description' content={seo.description} />
    <meta name='twitter:image' content={seo.image} />
    <link rel='shortcut icon' href='/favicon.ico' />
    <link rel='manifest' href='/manifest.json' />
    <link
      rel='alternate'
      type='application/rss+xml'
      title={`${site.name} – RSS feed`}
      href='/rss.xml'
    />
  </head>
  <body>
    <div class='grid min-h-dvh grid-rows-[auto_1fr_auto]'>
      <header class='reveal reveal-1 sticky top-0 z-20 border-b border-rule bg-paper/85 backdrop-blur-[6px]'>
        <div class='mx-auto flex w-[min(100%-2rem,1120px)] items-center justify-between py-4'>
          <a href='/' class='no-rule group flex items-baseline gap-3' aria-label={site.name}>
            <span
              class='font-display text-2xl leading-none text-ink'
              style='font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144; font-weight: 600;'
            >A<span class='italic text-terracotta'>·</span>H</span>
            <span class='hidden font-mono text-[0.65rem] uppercase tracking-[0.3em] text-muted sm:inline'>Andras Hejj · Field Notes</span>
          </a>
          <nav class='flex items-center gap-6 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-ink-soft'>
            <a class='no-rule transition hover:text-terracotta' href='/blog'>Blog</a>
            <a class='no-rule transition hover:text-terracotta' href='/about'>About</a>
            <a
              class='no-rule inline-flex items-center gap-1.5 transition hover:text-terracotta'
              href='/subscribe'
              aria-label='Subscribe'
              title='Subscribe'
            >
              <Rss size={14} />
              <span class='hidden sm:inline'>RSS</span>
            </a>
          </nav>
        </div>
      </header>

      <main class='reveal reveal-2 mx-auto w-[min(100%-2rem,1120px)] py-12 md:py-16'>
        <slot />
      </main>

      <footer class='border-t border-rule bg-paper-deep/40'>
        <div class='mx-auto w-[min(100%-2rem,1120px)] py-8'>
          <div class='rule-horizontal mb-6'></div>
          <div class='flex flex-col items-start justify-between gap-4 text-ink-soft md:flex-row md:items-center'>
            <div class='flex items-baseline gap-3'>
              <span class='font-display text-lg' style='font-variation-settings: "SOFT" 100, "WONK" 1;'>
                © {year}
              </span>
              <span class='font-mono text-[0.7rem] uppercase tracking-[0.2em] text-muted'>
                Budapest · Zürich · Mauritius
              </span>
            </div>
            <div class='flex items-center gap-5 font-mono text-[0.72rem] uppercase tracking-[0.22em]'>
              <a href={site.social.github} target='_blank' rel='noreferrer' class='no-rule hover:text-terracotta'>GitHub</a>
              <a href={site.social.linkedin} target='_blank' rel='noreferrer' class='no-rule hover:text-terracotta'>LinkedIn</a>
              <a href={site.social.x} target='_blank' rel='noreferrer' class='no-rule hover:text-terracotta'>X</a>
              <a
                href='/rss.xml'
                class='no-rule inline-flex items-center gap-1.5 hover:text-terracotta'
                aria-label='RSS feed'
                title='RSS feed'
              >
                <Rss size={13} />
                RSS
              </a>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <!-- Image lightbox -->
    <div
      id='lightbox'
      class='fixed inset-0 z-50 hidden items-center justify-center'
      aria-hidden='true'
    >
      <div class='lightbox-backdrop absolute inset-0 bg-ink/90' data-lightbox-close></div>
      <span
        class='pointer-events-none absolute inset-0 mix-blend-soft-light'
        style='background-image: var(--grain); opacity: 0.4;'
        aria-hidden='true'
      ></span>
      <button
        type='button'
        class='no-rule absolute right-5 top-5 z-10 flex h-10 w-10 items-center justify-center border border-paper/30 font-mono text-lg text-paper transition hover:border-terracotta hover:text-terracotta'
        aria-label='Close image'
        data-lightbox-close
      >×</button>
      <figure class='lightbox-figure relative z-0 m-0 flex max-h-[92dvh] max-w-[94vw] flex-col items-center gap-3'>
        <img id='lightbox-img' src='' alt='' class='max-h-[84dvh] max-w-[94vw] object-contain shadow-[0_30px_80px_-20px_rgba(0,0,0,0.8)]' />
        <figcaption
          id='lightbox-caption'
          class='max-w-[68ch] text-center font-mono text-[0.72rem] uppercase tracking-[0.22em] text-paper/70'
        ></figcaption>
      </figure>
    </div>

    <style>
      #lightbox.is-open { display: flex; }
      body.lightbox-locked { overflow: hidden; }
      main figure img, main p img { cursor: zoom-in; }
      .lightbox-figure { animation: lightbox-pop 0.22s ease-out; }
      .lightbox-backdrop { animation: lightbox-fade 0.22s ease-out; }
      @keyframes lightbox-fade { from { opacity: 0; } to { opacity: 1; } }
      @keyframes lightbox-pop {
        from { opacity: 0; transform: scale(0.97); }
        to { opacity: 1; transform: scale(1); }
      }
      @media (prefers-reduced-motion: reduce) {
        .lightbox-figure, .lightbox-backdrop { animation: none; }
      }
    </style>

    <script is:inline>
      (() => {
        const box = document.getElementById("lightbox");
        const img = document.getElementById("lightbox-img");
        const caption = document.getElementById("lightbox-caption");
        if (!box || !img || !caption) return;

        function open(source) {
          img.src = source.currentSrc || source.src;
          img.alt = source.alt || "";
          const text = source.alt || source.closest("figure")?.querySelector("figcaption")?.textContent || "";
          caption.textContent = text.trim();
          caption.style.display = caption.textContent ? "" : "none";
          box.classList.add("is-open");
          box.setAttribute("aria-hidden", "false");
          document.body.classList.add("lightbox-locked");
        }

        function close() {
          box.classList.remove("is-open");
          box.setAttribute("aria-hidden", "true");
          document.body.classList.remove("lightbox-locked");
          img.src = "";
        }

        // Any content image inside <main> that isn't itself a link target.
        document.querySelectorAll("main img").forEach((el) => {
          if (el.closest("a")) return;
          el.addEventListener("click", () => open(el));
        });

        box.addEventListener("click", (e) => {
          if (e.target.hasAttribute("data-lightbox-close")) close();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && box.classList.contains("is-open")) close();
        });
      })();
    </script>
  </body>
</html>
