---
import PostCard from "../components/PostCard.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { getAllPostMeta } from "../lib/content";

const posts = await getAllPostMeta();
const featured = posts[0];
const rest = posts.slice(1, 7);

const issueNumber = String(posts.length).padStart(3, "0");
const today = new Date().toLocaleDateString("en-GB", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
---

<SiteLayout path='/'>
  <!-- Masthead: newspaper-style nameplate -->
  <section class='reveal reveal-2 relative'>
    <div class='flex items-center justify-between font-mono text-[0.68rem] uppercase tracking-[0.28em] text-muted'>
      <span>Vol. I · Issue №{issueNumber}</span>
      <span class='hidden sm:inline'>{today}</span>
      <span>Est. MMXX</span>
    </div>
    <div class='rule-horizontal mt-3'></div>
    <div class='rule-horizontal mt-[3px]'></div>

    <div class='grid gap-10 py-10 md:grid-cols-[1.35fr_minmax(0,0.9fr)] md:items-center md:gap-14 md:py-12'>
      <div>
        <p class='eyebrow mb-3'>Field notes from the studio</p>
        <h1
          class='font-display leading-[0.92] tracking-[-0.035em] text-ink'
          style='font-size: clamp(2.8rem, 8vw, 6rem); font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144; font-weight: 500;'
        >
          Hi, I'm <span class='italic text-terracotta' style='font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;'>Andras</span>.
        </h1>
        <p class='mt-5 max-w-[50ch] text-lg leading-relaxed text-ink-soft md:text-xl'>
          <span class='font-display italic text-pine' style='font-variation-settings: "SOFT" 100, "WONK" 1;'>Founder</span>
          and serial entrepreneur. Tech geek, hands-on builder. Husband and dad.
          Writing on the practice of building — and the quieter art of showing up.
        </p>
        <div class='mt-7 flex flex-wrap gap-2'>
          <a href='/blog' class='stamp no-rule text-terracotta transition hover:bg-terracotta hover:text-paper'>Read the archive →</a>
          <a href='/about' class='stamp no-rule text-pine transition hover:bg-pine hover:text-paper'>About</a>
        </div>
      </div>

      <!-- Editorial portrait: framed photo with caption strip -->
      <figure class='relative mx-auto w-full max-w-[360px] md:mx-0 md:justify-self-end'>
        <div class='relative border border-ink bg-surface p-2 shadow-[10px_10px_0_0_rgba(27,23,19,0.08)]'>
          <div class='relative aspect-[4/5] overflow-hidden border border-rule'>
            <img
              src='/images/posts/andras.png'
              alt='Portrait of Andras'
              loading='eager'
              width='360'
              height='450'
              class='h-full w-full object-cover'
              style='filter: contrast(1.04) saturate(0.88) sepia(0.1);'
            />
            <span
              class='pointer-events-none absolute inset-0 mix-blend-multiply'
              style='background-image: var(--grain); opacity: 0.4;'
              aria-hidden='true'
            ></span>
            <span class='pointer-events-none absolute left-2 top-2 font-mono text-[0.6rem] uppercase tracking-[0.2em] text-paper mix-blend-difference'>
              Plate №01
            </span>
          </div>
        </div>

        <figcaption class='mt-4 space-y-1.5 text-ink-soft'>
          <p class='font-display text-[1.02rem] leading-snug' style='font-variation-settings: "SOFT" 80, "WONK" 1;'>
            <span aria-hidden='true'>💕</span>
            <span class='text-muted'>Made with heart in</span>
            <span class='italic text-ink' style='font-variation-settings: "SOFT" 100, "WONK" 1;'>Budapest</span>
          </p>
          <p class='font-display text-[1.02rem] leading-snug' style='font-variation-settings: "SOFT" 80, "WONK" 1;'>
            <span aria-hidden='true'>🌳</span>
            <span class='text-muted'>Grown up in</span>
            <span class='italic text-pine' style='font-variation-settings: "SOFT" 100, "WONK" 1;'>Switzerland</span>
          </p>
          <p class='font-display text-[1.02rem] leading-snug' style='font-variation-settings: "SOFT" 80, "WONK" 1;'>
            <span aria-hidden='true'>🏄</span>
            <span class='text-muted'>Surfing in</span>
            <span class='italic text-terracotta' style='font-variation-settings: "SOFT" 100, "WONK" 1;'>Mauritius</span>
          </p>
        </figcaption>
      </figure>
    </div>
    <div class='rule-horizontal'></div>
  </section>

  <!-- Featured article: broadsheet lede -->
  {featured && (
    <section class='reveal reveal-3 mt-14'>
      <div class='mb-4 flex items-center gap-3'>
        <span class='stamp border-terracotta text-terracotta'>Lede</span>
        <span class='font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted'>
          Today's featured dispatch
        </span>
      </div>

      <a
        href={featured.routePath}
        class='no-rule group grid gap-6 md:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] md:gap-10'
      >
        <div class='relative overflow-hidden border border-rule bg-surface'>
          <div class='aspect-[4/3] overflow-hidden'>
            <img
              src={featured.coverImage}
              alt={featured.title}
              loading='eager'
              onerror="this.onerror=null;this.src='/images/posts/default-cover.svg';"
              class='h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.03]'
              style='filter: contrast(1.02) saturate(0.92);'
            />
          </div>
          <span class='pointer-events-none absolute inset-0 mix-blend-multiply' style='background-image: var(--grain); opacity: 0.35;'></span>
        </div>

        <div class='flex flex-col justify-center'>
          <p class='eyebrow'>№{issueNumber} · The Dispatch</p>
          <h2
            class='mt-3 font-display leading-[1.02] tracking-[-0.025em] text-ink'
            style='font-size: clamp(1.9rem, 4.2vw, 3.2rem); font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144; font-weight: 500;'
          >
            {featured.title}
          </h2>
          <p class='mt-4 max-w-[54ch] text-lg leading-relaxed text-ink-soft'>
            {featured.summary}
          </p>
          <div class='mt-5 flex items-center gap-3 font-mono text-[0.7rem] uppercase tracking-[0.22em] text-muted'>
            <span>{new Date(`${featured.date}T00:00:00Z`).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" })}</span>
            <span aria-hidden='true'>✦</span>
            <span>{featured.readingTimeText}</span>
          </div>
          <span class='mt-6 inline-flex w-fit items-center gap-2 border-b-2 border-terracotta pb-1 font-mono text-[0.75rem] uppercase tracking-[0.2em] text-terracotta transition group-hover:gap-3'>
            Read the lede
            <span aria-hidden='true'>→</span>
          </span>
        </div>
      </a>
    </section>
  )}

  <!-- Archive strip -->
  <section class='reveal reveal-4 mt-20'>
    <div class='mb-6 flex items-end justify-between gap-4'>
      <div>
        <p class='eyebrow'>Section II</p>
        <h2
          class='mt-1 font-display tracking-[-0.02em] text-ink'
          style='font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144; font-weight: 500;'
        >
          From the <span class='italic text-pine'>archive</span>
        </h2>
      </div>
      <a
        href='/blog'
        class='no-rule font-mono text-[0.72rem] uppercase tracking-[0.22em] text-terracotta hover:text-terracotta-strong'
      >
        All posts →
      </a>
    </div>

    <div class='rule-horizontal mb-6'></div>

    <div class='grid grid-cols-[repeat(auto-fit,minmax(290px,1fr))] gap-8'>
      {rest.map((post, i) => (
        <div class={`reveal reveal-${Math.min(5, i + 2)}`}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
  </section>
</SiteLayout>
