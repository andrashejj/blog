---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title='Not found' path='/404'>
  <section class='reveal reveal-2 py-20 text-center'>
    <p class='eyebrow'>Error 404 · Dispatch missing</p>
    <h1
      class='mt-4 font-display leading-[0.95] tracking-[-0.03em] text-ink'
      style='font-size: clamp(3rem, 10vw, 7rem); font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144; font-weight: 500;'
    >
      Off the <span class='italic text-terracotta'>map</span>.
    </h1>
    <p class='mx-auto mt-4 max-w-[42ch] text-ink-soft'>
      The page you requested does not exist — perhaps it drifted with the tides.
    </p>
    <a
      href='/blog'
      class='no-rule mt-8 inline-flex items-center gap-2 border-b-2 border-terracotta pb-1 font-mono text-[0.78rem] uppercase tracking-[0.22em] text-terracotta transition hover:gap-3'
    >
      Return to the archive <span aria-hidden='true'>→</span>
    </a>
  </section>
</SiteLayout>
