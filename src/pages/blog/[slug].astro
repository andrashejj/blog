---
import { render } from "astro:content";

import PostMetaView from "../../components/PostMeta.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getAllPostMeta, getPostBySlug } from "../../lib/content";

import Callout from "../../components/mdx/Callout.astro";
import Quote from "../../components/mdx/Quote.astro";
import Highlight from "../../components/mdx/Highlight.astro";
import Divider from "../../components/mdx/Divider.astro";
import ImageFloat from "../../components/mdx/ImageFloat.astro";
import ImageGrid from "../../components/mdx/ImageGrid.astro";
import CTA from "../../components/mdx/CTA.astro";

const components = {
  Callout,
  Quote,
  Highlight,
  Divider,
  ImageFloat,
  ImageGrid,
  CTA,
};

export async function getStaticPaths() {
  const posts = await getAllPostMeta();

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing slug parameter.");
}

const result = await getPostBySlug(slug);

if (!result) {
  throw new Error(`Post not found for slug "${slug}"`);
}

const { Content, headings } = await render(result.post);
const { meta } = result;

const filteredHeadings = headings.filter(
  (h: { depth: number }) => h.depth <= 2,
);
---

<SiteLayout
  title={meta.title}
  description={meta.summary}
  path={meta.routePath}
  image={meta.coverImage}
  type='article'
>
  <!-- Article masthead -->
  <section class='reveal reveal-2'>
    <div class='flex items-center justify-between font-mono text-[0.68rem] uppercase tracking-[0.28em] text-muted'>
      <a href='/blog' class='no-rule transition hover:text-terracotta'>← The archive</a>
      <span>Dispatch</span>
    </div>
    <div class='rule-horizontal mt-3'></div>
    <div class='rule-horizontal mt-[3px]'></div>
  </section>

  <div class='mt-10 grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,1fr)_220px]'>
    <article>
      <header class='reveal reveal-3'>
        <p class='eyebrow mb-4'>Article · Field notes</p>
        <h1
          class='font-display leading-[1.02] tracking-[-0.03em] text-ink'
          style='font-size: clamp(2.2rem, 5vw, 3.6rem); font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144; font-weight: 500;'
        >
          {meta.title}
        </h1>
        <div class='mt-5 flex items-center gap-4'>
          <PostMetaView post={meta} />
        </div>
        <div class='rule-horizontal mt-6'></div>
      </header>

      <figure class='reveal reveal-4 relative mt-8 overflow-hidden border border-rule bg-surface'>
        <img
          src={meta.coverImage}
          alt={meta.title}
          width='1200'
          height='630'
          onerror="this.onerror=null;this.src='/images/posts/default-cover.svg';"
          class='block h-auto w-full'
          style='filter: contrast(1.02) saturate(0.92);'
          loading='eager'
        />
        <span
          class='pointer-events-none absolute inset-0 mix-blend-multiply'
          style='background-image: var(--grain); opacity: 0.28;'
          aria-hidden='true'
        ></span>
      </figure>

      <section
        class='prose reveal reveal-5 mt-10 max-w-[68ch]
               prose-headings:font-display prose-headings:tracking-[-0.02em] prose-headings:text-ink
               prose-h2:mt-14 prose-h2:mb-4
               prose-h3:mt-10 prose-h3:mb-3
               prose-p:text-[1.08rem] prose-p:leading-[1.75] prose-p:text-ink-soft
               prose-a:text-terracotta-strong prose-a:font-medium prose-a:underline prose-a:decoration-terracotta/50 prose-a:underline-offset-4 hover:prose-a:decoration-terracotta
               prose-strong:text-ink
               prose-blockquote:border-l-2 prose-blockquote:border-terracotta prose-blockquote:bg-transparent prose-blockquote:pl-5 prose-blockquote:italic prose-blockquote:text-ink
               prose-code:font-mono prose-code:text-[0.9em] prose-code:rounded-none prose-code:border prose-code:border-rule prose-code:bg-paper-deep/60 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-ink prose-code:before:content-none prose-code:after:content-none
               prose-pre:rounded-none prose-pre:border prose-pre:border-ink prose-pre:bg-[#14110e] prose-pre:text-[#f1e6cf] prose-pre:shadow-[6px_6px_0_0_rgba(27,23,19,1)]
               prose-img:max-w-full prose-img:border prose-img:border-rule prose-img:shadow-[0_12px_30px_-18px_rgba(27,23,19,0.5)]
               prose-hr:border-0 prose-hr:h-px prose-hr:bg-[length:10px_1px]'
      >
        <Content components={components} />
      </section>

      <script is:inline>
        function normalizeArticleEmbeds() {
          const article = document.querySelector(".prose");
          if (!(article instanceof HTMLElement)) return;

          const iframes = article.querySelectorAll("iframe");

          for (const iframe of iframes) {
            const src = iframe.getAttribute("src") || "";
            const width = Number.parseFloat(iframe.getAttribute("width") || "");
            const height = Number.parseFloat(iframe.getAttribute("height") || "");
            const hasPortraitDimensions =
              Number.isFinite(width) &&
              Number.isFinite(height) &&
              height > width * 1.1;
            const looksLikePortraitEmbed =
              hasPortraitDimensions ||
              /instagram|tiktok|reel|shorts/i.test(src);

            if (!looksLikePortraitEmbed) continue;

            iframe.classList.add("article-embed-portrait");

            const wrapper = iframe.closest(".aspect-video, [class*='aspect-video']");
            if (wrapper instanceof HTMLElement) {
              wrapper.classList.add("article-embed-shell", "article-embed-shell--portrait");
            }
          }
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", normalizeArticleEmbeds, {
            once: true,
          });
        } else {
          normalizeArticleEmbeds();
        }
      </script>
    </article>

    <aside class='reveal reveal-4 hidden h-fit lg:sticky lg:top-24 lg:block'>
      <div class='border-l border-rule pl-5'>
        <h4 class='eyebrow mb-4'>On this page</h4>
        <nav class='space-y-2.5'>
          {filteredHeadings.map((heading: { depth: number; slug: string; text: string }) => (
            <a
              href={`#${heading.slug}`}
              class={`no-rule block font-display text-[0.98rem] leading-snug text-ink-soft transition hover:text-terracotta ${
                heading.depth === 3 ? 'pl-4 text-[0.9rem] text-muted' : ''
              }`}
            >
              {heading.text}
            </a>
          ))}
        </nav>
      </div>
    </aside>
  </div>
</SiteLayout>
