---
import { Printer } from "@lucide/astro";
import {
  exercises,
  CATEGORY_COLORS,
  FORMAT_COLORS,
  BODY_FOCUS_COLORS,
} from "../lib/exercise-collection-data";
import type { Category, Format, BodyFocus } from "../lib/exercise-collection-data";

const allCategories: Category[] = ["strength", "mobility", "balance", "coordination", "cardio"];
const allFormats: Format[] = ["group", "individual", "pairs"];
const allBodyFocus: BodyFocus[] = ["upper body", "lower body", "core", "full body"];
---

<div class="exercise-collection not-prose my-12 bg-white text-slate-800 border-2 border-slate-300 rounded-xl shadow-sm font-sans print:border-0 print:shadow-none print:rounded-none print:m-0 print:p-0 print:text-[11px] print:[print-color-adjust:exact] print:[-webkit-print-color-adjust:exact]">

  <!-- Header -->
  <div class="px-6 py-8 border-b-2 border-slate-200 bg-gradient-to-r from-cyan-50 to-teal-50 rounded-t-xl text-center print:px-2 print:py-3 print:rounded-none">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 m-0 print:text-xl">Surf Exercise Collection</h2>
    <p class="text-slate-500 mt-2 font-medium text-sm sm:text-base px-2 print:text-[10px] print:mt-1">
      Tamarin Bay &bull; Kids Coaching (ages 7–9) &bull; 12 exercises
    </p>
    <div class="flex items-center justify-center gap-3 mt-4 print:hidden">
      <button type="button" id="print-exercises-btn" class="text-sm font-semibold bg-slate-800 hover:bg-slate-700 text-white px-5 py-2 rounded-full transition-colors inline-flex items-center gap-2 cursor-pointer">
        <Printer size={16} />
        Print Collection
      </button>
    </div>
  </div>

  <!-- Filter bar -->
  <div id="filter-bar" class="px-6 py-5 border-b-2 border-slate-200 bg-slate-50/70 space-y-3 print:hidden">
    <div class="flex items-center justify-between mb-1">
      <span class="text-sm font-bold text-slate-700 uppercase tracking-wider">Filters</span>
      <div class="flex items-center gap-3">
        <span id="exercise-count" class="text-sm text-slate-500 font-medium">Showing 12 of 12</span>
        <button type="button" id="clear-filters-btn" class="text-xs font-semibold text-slate-500 hover:text-slate-700 px-3 py-1 rounded-full border border-slate-200 hover:border-slate-300 transition-colors cursor-pointer hidden">
          Clear all
        </button>
      </div>
    </div>

    <!-- Category filters -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider w-20 shrink-0">Type</span>
      {allCategories.map((cat) => (
        <button
          type="button"
          data-filter-pill
          data-filter-type="category"
          data-filter-value={cat}
          aria-pressed="false"
          class:list={[
            "text-xs font-semibold px-3 py-1.5 rounded-full border cursor-pointer transition-all",
            CATEGORY_COLORS[cat],
            "opacity-60 hover:opacity-100",
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Format filters -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider w-20 shrink-0">Format</span>
      {allFormats.map((fmt) => (
        <button
          type="button"
          data-filter-pill
          data-filter-type="format"
          data-filter-value={fmt}
          aria-pressed="false"
          class:list={[
            "text-xs font-semibold px-3 py-1.5 rounded-full border cursor-pointer transition-all",
            FORMAT_COLORS[fmt],
            "opacity-60 hover:opacity-100",
          ]}
        >
          {fmt}
        </button>
      ))}
    </div>

    <!-- Body focus filters -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider w-20 shrink-0">Focus</span>
      {allBodyFocus.map((bf) => (
        <button
          type="button"
          data-filter-pill
          data-filter-type="bodyFocus"
          data-filter-value={bf}
          aria-pressed="false"
          class:list={[
            "text-xs font-semibold px-3 py-1.5 rounded-full border cursor-pointer transition-all",
            BODY_FOCUS_COLORS[bf],
            "opacity-60 hover:opacity-100",
          ]}
        >
          {bf}
        </button>
      ))}
    </div>
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden px-6 py-12 text-center">
    <p class="text-slate-400 text-lg font-medium">No exercises match your filters.</p>
    <p class="text-slate-400 text-sm mt-1">Try removing a filter to see more results.</p>
  </div>

  <!-- Exercise card grid -->
  <div id="exercise-grid" class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-4 print:p-2 print:gap-2 print:grid-cols-2">
    {exercises.map((ex, i) => (
      <div
        data-exercise-card
        data-categories={ex.categories.join(",")}
        data-format={ex.format}
        data-body-focus={ex.bodyFocus}
        class="border-2 border-slate-200 rounded-xl bg-white p-5 flex flex-col gap-3 print:p-3 print:gap-1.5 print:break-inside-avoid print:rounded-lg print:border"
      >
        <!-- Card header: name + duration -->
        <div class="flex items-start justify-between gap-2">
          <h3 class="text-lg font-bold text-slate-900 m-0 leading-snug print:text-[13px]">
            <span class="text-slate-400 font-normal mr-1 print:text-[11px]">{i + 1}.</span>
            {ex.name}
          </h3>
          <span class="shrink-0 text-xs font-semibold text-slate-500 bg-slate-100 border border-slate-200 px-2.5 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0.5">
            {ex.duration}
          </span>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-1.5 print:gap-1">
          {ex.categories.map((cat) => (
            <span class:list={["text-[10px] font-semibold px-2 py-0.5 rounded-full border print:text-[8px] print:px-1", CATEGORY_COLORS[cat]]}>
              {cat}
            </span>
          ))}
          <span class:list={["text-[10px] font-semibold px-2 py-0.5 rounded-full border print:text-[8px] print:px-1", FORMAT_COLORS[ex.format]]}>
            {ex.format}
          </span>
          <span class:list={["text-[10px] font-semibold px-2 py-0.5 rounded-full border print:text-[8px] print:px-1", BODY_FOCUS_COLORS[ex.bodyFocus]]}>
            {ex.bodyFocus}
          </span>
        </div>

        <!-- Description -->
        <p class="text-sm text-slate-700 leading-relaxed m-0 print:text-[10px] print:leading-snug">
          {ex.description}
        </p>

        <!-- Variations -->
        {ex.variations && ex.variations.length > 0 && (
          <div class="mt-1">
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 m-0 mb-1 print:text-[8px]">Variations</p>
            <ul class="m-0 pl-4 space-y-0.5 text-xs text-slate-600 list-disc print:text-[9px] print:space-y-0">
              {ex.variations.map((v) => (
                <li>{v}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- Surf relevance -->
        <div class="mt-auto pt-2 border-t border-slate-100 print:pt-1">
          <p class="text-xs text-cyan-700 font-medium m-0 print:text-[9px]">
            <span class="font-bold">🏄 Why:</span> {ex.surfRelevance}
          </p>
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  function initExerciseFilters() {
    const pills = document.querySelectorAll<HTMLButtonElement>("[data-filter-pill]");
    const cards = document.querySelectorAll<HTMLElement>("[data-exercise-card]");
    const countEl = document.getElementById("exercise-count");
    const clearBtn = document.getElementById("clear-filters-btn");
    const emptyState = document.getElementById("empty-state");
    const grid = document.getElementById("exercise-grid");
    const printBtn = document.getElementById("print-exercises-btn");

    if (!pills.length || !cards.length) return;

    const activeFilters: Map<string, Set<string>> = new Map();

    function applyFilters() {
      let visible = 0;

      for (const card of cards) {
        const cardCategories = (card.dataset.categories || "").split(",");
        const cardFormat = card.dataset.format || "";
        const cardBodyFocus = card.dataset.bodyFocus || "";

        let matches = true;

        for (const [filterType, values] of activeFilters) {
          if (values.size === 0) continue;

          if (filterType === "category") {
            if (!cardCategories.some((c) => values.has(c))) {
              matches = false;
              break;
            }
          } else if (filterType === "format") {
            if (!values.has(cardFormat)) {
              matches = false;
              break;
            }
          } else if (filterType === "bodyFocus") {
            if (!values.has(cardBodyFocus)) {
              matches = false;
              break;
            }
          }
        }

        if (matches) {
          card.style.display = "";
          visible++;
        } else {
          card.style.display = "none";
        }
      }

      if (countEl) {
        countEl.textContent = `Showing ${visible} of ${cards.length}`;
      }

      const hasActiveFilters = [...activeFilters.values()].some((s) => s.size > 0);
      if (clearBtn) {
        clearBtn.classList.toggle("hidden", !hasActiveFilters);
      }
      if (emptyState && grid) {
        emptyState.classList.toggle("hidden", visible > 0);
        grid.classList.toggle("hidden", visible === 0);
      }
    }

    for (const pill of pills) {
      pill.addEventListener("click", () => {
        const filterType = pill.dataset.filterType || "";
        const filterValue = pill.dataset.filterValue || "";

        if (!activeFilters.has(filterType)) {
          activeFilters.set(filterType, new Set());
        }

        const set = activeFilters.get(filterType)!;
        const isActive = pill.getAttribute("aria-pressed") === "true";

        if (isActive) {
          set.delete(filterValue);
          pill.setAttribute("aria-pressed", "false");
          pill.classList.add("opacity-60");
          pill.classList.remove("ring-2", "ring-offset-1", "ring-slate-400", "opacity-100");
        } else {
          set.add(filterValue);
          pill.setAttribute("aria-pressed", "true");
          pill.classList.remove("opacity-60");
          pill.classList.add("ring-2", "ring-offset-1", "ring-slate-400", "opacity-100");
        }

        applyFilters();
      });
    }

    if (clearBtn) {
      clearBtn.addEventListener("click", () => {
        activeFilters.clear();
        for (const pill of pills) {
          pill.setAttribute("aria-pressed", "false");
          pill.classList.add("opacity-60");
          pill.classList.remove("ring-2", "ring-offset-1", "ring-slate-400", "opacity-100");
        }
        applyFilters();
      });
    }

    if (printBtn) {
      printBtn.addEventListener("click", () => window.print());
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initExerciseFilters, { once: true });
  } else {
    initExerciseFilters();
  }
</script>
