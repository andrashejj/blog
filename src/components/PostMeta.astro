---
import type { PostMeta } from "../lib/content";

interface Props {
  post: PostMeta;
}

const { post } = Astro.props;

const date = new Date(`${post.date}T00:00:00.000Z`).toLocaleDateString(
  "en-GB",
  {
    year: "numeric",
    month: "short",
    day: "2-digit",
    timeZone: "UTC",
  },
);
---

<p class='flex items-center gap-2 font-mono text-[0.68rem] uppercase tracking-[0.22em] text-muted'>
  <span>{date}</span>
  <span aria-hidden='true' class='text-terracotta'>✦</span>
  <span>{post.readingTimeText}</span>
</p>
