---
import type { PostMeta } from "../lib/content";
import PostMetaView from "./PostMeta.astro";

interface Props {
  post: PostMeta;
}

const { post } = Astro.props;
---

<article class='group flex h-full flex-col'>
  <a
    href={post.routePath}
    class='no-rule relative block overflow-hidden border border-rule bg-surface'
  >
    <div class='aspect-[5/4] overflow-hidden'>
      <img
        src={post.coverImage}
        alt={post.title}
        loading='lazy'
        onerror="this.onerror=null;this.src='/images/posts/default-cover.svg';"
        class='h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.04]'
        style='filter: contrast(1.02) saturate(0.9);'
      />
    </div>
    <span
      class='pointer-events-none absolute inset-0 mix-blend-multiply'
      style='background-image: var(--grain); opacity: 0.3;'
      aria-hidden='true'
    ></span>
    <span class='pointer-events-none absolute left-3 top-3 font-mono text-[0.62rem] uppercase tracking-[0.2em] text-paper mix-blend-difference'>
      Dispatch
    </span>
  </a>

  <div class='mt-4 flex flex-1 flex-col'>
    <PostMetaView post={post} />
    <h2
      class='mt-2 font-display leading-[1.08] tracking-[-0.02em] text-ink'
      style='font-size: clamp(1.2rem, 1.8vw, 1.55rem); font-variation-settings: "SOFT" 60, "WONK" 1, "opsz" 72; font-weight: 500;'
    >
      <a href={post.routePath} class='no-rule transition group-hover:text-terracotta-strong'>
        {post.title}
      </a>
    </h2>
    <p class='mt-2 text-[0.98rem] leading-relaxed text-ink-soft'>
      {post.summary}
    </p>
    <a
      href={post.routePath}
      class='no-rule mt-auto inline-flex w-fit items-center gap-2 pt-4 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-terracotta transition group-hover:gap-3'
    >
      Read article <span aria-hidden='true'>→</span>
    </a>
  </div>
</article>
