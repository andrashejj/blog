---
import { Printer, RefreshCw } from "@lucide/astro";
---

<div class="worksheet-container not-prose my-12 bg-white text-slate-800 border-2 border-slate-300 rounded-xl shadow-sm font-sans print:border-0 print:shadow-none print:rounded-none print:m-0 print:p-0 print:text-[11px] print:[print-color-adjust:exact] print:[-webkit-print-color-adjust:exact]">
  <!-- Header -->
  <div class="px-6 py-8 border-b-2 border-slate-200 bg-gradient-to-r from-cyan-50 to-teal-50 rounded-t-xl text-center print:px-2 print:py-3 print:rounded-none">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 m-0 print:text-xl">Surf Coaching Session Plan</h2>
    <p class="text-slate-500 mt-2 font-medium text-sm sm:text-base px-2 print:text-[10px] print:mt-1">
      Tamarin Bay &nbsp;&bull;&nbsp; Tuesday & Wednesday &nbsp;&bull;&nbsp; ~90 min target (with slack)
    </p>
    <p class="text-slate-400 mt-1 text-sm print:text-[10px] print:mt-0.5">
      Date: <span id="session-date" class="font-semibold text-slate-600">___________</span>
    </p>
    <div class="flex items-center justify-center gap-3 mt-4 print:hidden">
      <button type="button" id="print-btn" class="text-sm font-semibold bg-slate-800 hover:bg-slate-700 text-white px-5 py-2 rounded-full transition-colors inline-flex items-center gap-2 cursor-pointer">
        <Printer size={16} />
        Print Session Plan
      </button>
      <button type="button" id="regen-all-btn" class="text-sm font-semibold bg-teal-100 hover:bg-teal-200 text-teal-700 px-5 py-2 rounded-full transition-colors inline-flex items-center gap-2 cursor-pointer border border-teal-200">
        <RefreshCw size={16} />
        New Exercises
      </button>
    </div>
  </div>

  <div class="p-6 space-y-10 print:p-2 print:space-y-0">
    <!-- SECTION 1: GROUND RULES -->
    <section>
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-slate-800 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">1 | Ground Rules (6)</h3>
        <span class="text-sm font-semibold text-slate-700 bg-slate-100 border border-slate-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">Always</span>
      </div>
      <div class="border-2 border-slate-200 rounded-xl p-5 bg-slate-50/60 print:p-2 print:break-inside-avoid">
        <ol class="m-0 pl-5 space-y-2 text-sm text-slate-700 print:text-[10px] print:space-y-1">
          <li>When we arrive, we greet the coaches and everyone else.</li>
          <li>If we are late, we bring a healthy cake (banana bread) next time.</li>
          <li>When we leave, we say goodbye to the coaches and everyone else.</li>
          <li>We do not argue with coaches. We share feedback in the debrief at the end.</li>
          <li>We do not go into the water alone. Ever.</li>
          <li>The coaches coach. They are not here to push boards, but they might if they are nice.</li>
        </ol>
      </div>
    </section>

    <!-- SECTION 2: WARMUP + STRETCH -->
    <section>
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-amber-700 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">2 | Theola Warmup + Stretch</h3>
        <span class="text-sm font-semibold text-amber-700 bg-amber-50 border border-amber-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">~20-30 min</span>
      </div>
      <div id="section-warmup-stretch" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="loading-skeleton space-y-3 print:space-y-1">
          {[1, 2, 3, 4].map(() => (
            <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-1.5 print:border">
              <div class="h-4 w-40 bg-slate-200 rounded mb-2"></div>
              <div class="h-3 w-3/4 bg-slate-100 rounded mb-2"></div>
              <div class="h-3 w-20 bg-amber-100 rounded"></div>
            </div>
          ))}
        </div>
      </div>
      <div id="section-warmup-note" class="mt-3 print:mt-1">
        <div class="border-2 border-amber-200 rounded-lg bg-amber-50/70 p-4 animate-pulse print:p-2">
          <div class="h-3 w-24 bg-amber-100 rounded mb-2"></div>
          <div class="h-3 w-3/4 bg-amber-50 rounded"></div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: BASICS -->
    <section>
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-blue-800 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">3 | Basics: Stand-Up Mechanics</h3>
        <span class="text-sm font-semibold text-blue-700 bg-blue-50 border border-blue-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">~10-15 min</span>
      </div>
      <div id="section-basics" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="loading-skeleton space-y-3 print:space-y-1">
          {[1, 2, 3, 4].map(() => (
            <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-1.5 print:border">
              <div class="h-4 w-40 bg-slate-200 rounded mb-2"></div>
              <div class="h-3 w-3/4 bg-slate-100 rounded mb-2"></div>
              <div class="h-3 w-20 bg-blue-100 rounded"></div>
            </div>
          ))}
        </div>
      </div>
      <div id="section-basics-note" class="mt-3 print:mt-1">
        <div class="border-2 border-blue-200 rounded-lg bg-blue-50/70 p-4 animate-pulse print:p-2">
          <div class="h-3 w-24 bg-blue-100 rounded mb-2"></div>
          <div class="h-3 w-3/4 bg-blue-50 rounded"></div>
        </div>
      </div>
    </section>

    <!-- SECTION 4: WATER BLOCK -->
    <section>
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-indigo-700 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">4 | Paddle Out + Surf + Debrief</h3>
        <span class="text-sm font-semibold text-indigo-700 bg-indigo-50 border border-indigo-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">~45-55 min (remaining time)</span>
      </div>
      <div id="section-water-block" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="loading-skeleton space-y-3 print:space-y-1">
          {[1, 2, 3, 4].map(() => (
            <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-1.5 print:border">
              <div class="h-3 w-28 bg-indigo-100 rounded mb-2"></div>
              <div class="h-3 w-4/5 bg-slate-100 rounded"></div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</div>

<!-- ── Templates for AI-generated content ─────────────────────────── -->

<template id="tpl-activity-row">
  <div class="border-2 border-slate-200 rounded-lg p-4 flex items-center justify-between print:p-1.5 print:break-inside-avoid print:border">
    <div class="flex items-center gap-3">
      <div class="w-5 h-5 border-2 border-slate-300 rounded-sm shrink-0 print:w-3 print:h-3"></div>
      <div>
        <div class="text-lg font-semibold text-slate-700 print:text-sm" data-slot="name"></div>
        <div class="text-sm text-slate-500 font-medium print:text-[10px]" data-slot="description"></div>
      </div>
    </div>
    <div class="text-sm font-semibold px-3 py-1 rounded-md shrink-0 print:text-[10px] print:px-1.5 print:py-0.5" data-slot="badge"></div>
  </div>
</template>

<template id="tpl-coach-note">
  <div class="border-2 rounded-lg p-4 print:p-2">
    <div class="text-xs font-bold uppercase tracking-widest mb-2 print:text-[9px]" data-slot="label"></div>
    <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="text"></p>
  </div>
</template>

<template id="tpl-water-card">
  <div class="border-2 border-slate-200 rounded-lg p-4 bg-white print:p-2 print:break-inside-avoid">
    <div class="text-xs font-bold uppercase tracking-widest mb-2" data-slot="label"></div>
    <p class="text-base text-slate-700 leading-snug m-0 print:text-[11px]" data-slot="text"></p>
  </div>
</template>

<script>
  interface ActivityItem {
    name: string;
    description: string;
    duration?: string;
    reps?: string;
  }

  interface SurfExercisesData {
    warmupStretch: {
      drills: ActivityItem[];
      coachNote: string;
    };
    basics: {
      drills: ActivityItem[];
      jumpUps: { reps: string; cue: string };
      coachCue: string;
    };
    waterBlock: {
      paddleFocus: string;
      surfFocus: string;
      challenge: string;
      debriefPrompt: string;
    };
  }

  const FALLBACK_DATA: SurfExercisesData = {
    warmupStretch: {
      drills: [
        {
          name: "Beach Jog Loop",
          description:
            "Jog together along the shoreline, then back to the group cone with relaxed breathing.",
          duration: "4-5 min",
        },
        {
          name: "Dynamic Arm Swings",
          description:
            "Do big arm circles, shoulder rolls, and cross-body swings to wake up paddling muscles.",
          duration: "4-5 min",
        },
        {
          name: "Hip Opener Lunges",
          description:
            "Step into controlled lunges and rotate over the front leg on each side.",
          duration: "4-5 min",
        },
        {
          name: "Ankle Balance Holds",
          description:
            "Hold single-leg balance in soft sand and switch legs with steady posture.",
          duration: "3-4 min",
        },
      ],
      coachNote:
        "Theola leads this block: keep it playful, keep everyone moving, and finish with calm breathing.",
    },
    basics: {
      drills: [
        {
          name: "Pop-up Landing",
          description:
            "From prone, pop up and freeze in stance with eyes forward and knees bent.",
          reps: "8x",
        },
        {
          name: "Rail Reach Drill",
          description:
            "Practice hand placement and chest lift before every pop-up to lock clean sequencing.",
          reps: "8x",
        },
        {
          name: "Low Stance Hold",
          description:
            "Hold a low surf stance for control, then reset with balanced feet.",
          reps: "3x 20s",
        },
      ],
      jumpUps: {
        reps: "20x each surfer",
        cue: "Quality over speed: stable feet, soft knees, eyes down the line.",
      },
      coachCue:
        "No shortcuts on mechanics: every rep starts with clean hand placement and finishes in a stable stance.",
    },
    waterBlock: {
      paddleFocus:
        "Paddle out together through the easiest channel and keep spacing between boards.",
      surfFocus:
        "On every wave, pop up early and look where you want to go, not at your feet.",
      challenge:
        "Each surfer aims for 3 clean rides with controlled takeoff and balanced stance.",
      debriefPrompt:
        "What felt best today, and what is one thing you want to improve next session?",
    },
  };

  async function fetchJSON<T>(url: string, timeoutMs = 35_000): Promise<T> {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), timeoutMs);
    try {
      const res = await fetch(url, { signal: controller.signal });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      return await res.json();
    } finally {
      clearTimeout(id);
    }
  }

  function withLoading(btn: HTMLButtonElement, action: () => Promise<void>) {
    return async () => {
      btn.disabled = true;
      const originalHtml = btn.innerHTML;
      btn.innerHTML = '<span class="inline-block w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span> Loading...';
      try {
        await action();
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
      }
    };
  }

  function cloneTemplate(id: string): DocumentFragment {
    const tpl = document.getElementById(id) as HTMLTemplateElement;
    return tpl.content.cloneNode(true) as DocumentFragment;
  }

  function fillSlots(fragment: DocumentFragment, data: Record<string, string>): void {
    for (const [key, value] of Object.entries(data)) {
      const el = fragment.querySelector(`[data-slot="${key}"]`);
      if (el) el.textContent = value;
    }
  }

  function renderActivityList(
    container: HTMLElement,
    activities: ActivityItem[],
    badgeClasses: string,
  ): void {
    container.innerHTML = "";
    for (const activity of activities) {
      const frag = cloneTemplate("tpl-activity-row");
      fillSlots(frag, {
        name: activity.name,
        description: activity.description,
        badge: activity.duration || activity.reps || "",
      });
      const badge = frag.querySelector('[data-slot="badge"]');
      if (badge) {
        for (const cls of badgeClasses.split(" ")) badge.classList.add(cls);
      }
      container.appendChild(frag);
    }
  }

  function renderCoachNote(
    container: HTMLElement,
    label: string,
    text: string,
    wrapperClasses: string,
    labelClasses: string,
  ): void {
    container.innerHTML = "";
    const frag = cloneTemplate("tpl-coach-note");
    fillSlots(frag, { label, text });
    const wrapper = frag.querySelector("div");
    const labelEl = frag.querySelector('[data-slot="label"]');
    if (wrapper) {
      for (const cls of wrapperClasses.split(" ")) wrapper.classList.add(cls);
    }
    if (labelEl) {
      for (const cls of labelClasses.split(" ")) labelEl.classList.add(cls);
    }
    container.appendChild(frag);
  }

  function renderWaterBlock(container: HTMLElement, data: SurfExercisesData["waterBlock"]): void {
    container.innerHTML = "";
    const cards = [
      { label: "Paddle Focus", text: data.paddleFocus, labelClasses: "text-cyan-700" },
      { label: "Surf Focus", text: data.surfFocus, labelClasses: "text-indigo-700" },
      { label: "Session Challenge", text: data.challenge, labelClasses: "text-teal-700" },
      { label: "Debrief Prompt", text: data.debriefPrompt, labelClasses: "text-emerald-700" },
    ];

    for (const card of cards) {
      const frag = cloneTemplate("tpl-water-card");
      fillSlots(frag, { label: card.label, text: card.text });
      const labelEl = frag.querySelector('[data-slot="label"]');
      if (labelEl) {
        for (const cls of card.labelClasses.split(" ")) labelEl.classList.add(cls);
      }
      container.appendChild(frag);
    }
  }

  async function loadAll(): Promise<void> {
    const ids = {
      warmupStretch: document.getElementById("section-warmup-stretch"),
      warmupNote: document.getElementById("section-warmup-note"),
      basics: document.getElementById("section-basics"),
      basicsNote: document.getElementById("section-basics-note"),
      waterBlock: document.getElementById("section-water-block"),
    };

    let data: SurfExercisesData;

    try {
      data = await fetchJSON<SurfExercisesData>("/api/generate-surf-exercises");
    } catch (error) {
      console.error("Failed to load surf exercises, using fallback:", error);
      data = FALLBACK_DATA;
    }

    const warmupActivities = data.warmupStretch?.drills?.length
      ? data.warmupStretch.drills
      : FALLBACK_DATA.warmupStretch.drills;
    const warmupNote = data.warmupStretch?.coachNote || FALLBACK_DATA.warmupStretch.coachNote;

    const basicsDrills = data.basics?.drills?.length ? data.basics.drills : FALLBACK_DATA.basics.drills;
    const jumpUps = {
      reps: "20x each surfer",
      cue: data.basics?.jumpUps?.cue || FALLBACK_DATA.basics.jumpUps.cue,
    };
    const basicsActivities: ActivityItem[] = [
      {
        name: "Jump-Ups (Mandatory)",
        description: jumpUps.cue,
        reps: jumpUps.reps,
      },
      ...basicsDrills,
    ];
    const basicsNote = data.basics?.coachCue || FALLBACK_DATA.basics.coachCue;

    const waterBlock = data.waterBlock?.paddleFocus && data.waterBlock?.surfFocus
      ? data.waterBlock
      : FALLBACK_DATA.waterBlock;

    if (ids.warmupStretch) {
      renderActivityList(ids.warmupStretch, warmupActivities, "text-amber-700 bg-amber-50");
    }
    if (ids.warmupNote) {
      renderCoachNote(
        ids.warmupNote,
        "Coach Note",
        warmupNote,
        "border-amber-200 bg-amber-50/70",
        "text-amber-800",
      );
    }
    if (ids.basics) {
      renderActivityList(ids.basics, basicsActivities, "text-blue-700 bg-blue-50");
    }
    if (ids.basicsNote) {
      renderCoachNote(
        ids.basicsNote,
        "Coach Cue",
        basicsNote,
        "border-blue-200 bg-blue-50/70",
        "text-blue-800",
      );
    }
    if (ids.waterBlock) {
      renderWaterBlock(ids.waterBlock, waterBlock);
    }
  }

  // Set today's date
  const dateEl = document.getElementById("session-date");
  if (dateEl) {
    const d = new Date();
    dateEl.textContent = d.toLocaleDateString("en-GB", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
    });
  }

  // Regenerate button
  const regenBtn = document.getElementById("regen-all-btn") as HTMLButtonElement;
  if (regenBtn) {
    regenBtn.disabled = true;
    regenBtn.addEventListener("click", withLoading(regenBtn, loadAll));
  }

  // Auto-load on page load
  const generatedSections = [
    document.getElementById("section-warmup-stretch"),
    document.getElementById("section-warmup-note"),
    document.getElementById("section-basics"),
    document.getElementById("section-basics-note"),
    document.getElementById("section-water-block"),
  ];

  const shouldLoadAll = generatedSections.some((section) =>
    !section || Boolean(section.querySelector(".loading-skeleton, .animate-pulse")),
  );

  if (shouldLoadAll) {
    loadAll().then(() => {
      if (regenBtn) regenBtn.disabled = false;
    });
  } else if (regenBtn) {
    regenBtn.disabled = false;
  }

  // Print button
  const printBtn = document.getElementById("print-btn");
  if (printBtn) {
    printBtn.addEventListener("click", () => {
      const header = document.querySelector("body > div > header") as HTMLElement;
      const footer = document.querySelector("body > div > footer") as HTMLElement;
      const main = document.querySelector("body > div > main") as HTMLElement;
      const proseEls = document.querySelectorAll<HTMLElement>(".prose > *:not(.worksheet-container)");

      if (header) header.style.display = "none";
      if (footer) footer.style.display = "none";
      if (main) {
        main.style.width = "100%";
        main.style.maxWidth = "100%";
        main.style.padding = "0";
        main.style.margin = "0";
      }
      proseEls.forEach((el) => (el.style.display = "none"));
      document.body.style.background = "white";

      let restored = false;
      const restoreLayout = () => {
        if (restored) return;
        restored = true;
        if (header) header.style.display = "";
        if (footer) footer.style.display = "";
        if (main) {
          main.style.width = "";
          main.style.maxWidth = "";
          main.style.padding = "";
          main.style.margin = "";
        }
        proseEls.forEach((el) => (el.style.display = ""));
        document.body.style.background = "";
      };

      window.addEventListener("afterprint", restoreLayout, { once: true });
      window.print();
      if (!("onafterprint" in window)) {
        setTimeout(restoreLayout, 1200);
      }
    });
  }
</script>
