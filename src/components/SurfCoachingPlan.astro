---
import { Printer, RefreshCw } from "@lucide/astro";
---

<div class="worksheet-container not-prose my-12 bg-white text-slate-800 border-2 border-slate-300 rounded-xl shadow-sm font-sans print:border-0 print:shadow-none print:rounded-none print:m-0 print:p-0 print:text-[11px] print:[print-color-adjust:exact] print:[-webkit-print-color-adjust:exact]">
  <div class="px-6 py-8 border-b-2 border-slate-200 bg-gradient-to-r from-cyan-50 to-teal-50 rounded-t-xl text-center print:px-2 print:py-3 print:rounded-none">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 m-0 print:text-xl">Kids Surf Session Plan</h2>
    <p class="text-slate-500 mt-2 font-medium text-sm sm:text-base px-2 print:text-[10px] print:mt-1">
      Tamarin Bay &nbsp;&bull;&nbsp; Tuesday & Wednesday &nbsp;&bull;&nbsp; 60-100 min coaching session
    </p>
    <p class="text-slate-400 mt-1 text-sm print:text-[10px] print:mt-0.5">
      Date: <span id="session-date" class="font-semibold text-slate-600">___________</span>
    </p>
    <div class="flex items-center justify-center gap-3 mt-4 print:hidden flex-wrap">
      <div class="inline-flex items-center gap-1.5 bg-white border border-slate-200 rounded-full px-3 py-1.5">
        <span class="text-xs font-semibold text-cyan-700" id="toggle-label-wavy">Wavy</span>
        <button type="button" id="mode-toggle" role="switch" aria-checked="false" class="relative w-11 h-6 bg-cyan-500 rounded-full transition-colors cursor-pointer border-0 p-0">
          <span class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow transition-transform"></span>
        </button>
        <span class="text-xs font-semibold text-slate-400" id="toggle-label-flat">Flat Day</span>
      </div>
      <button type="button" id="print-btn" class="text-sm font-semibold bg-slate-800 hover:bg-slate-700 text-white px-5 py-2 rounded-full transition-colors inline-flex items-center gap-2 cursor-pointer">
        <Printer size={16} />
        Print Session Plan
      </button>
      <button type="button" id="regen-all-btn" class="text-sm font-semibold bg-teal-100 hover:bg-teal-200 text-teal-700 px-5 py-2 rounded-full transition-colors inline-flex items-center gap-2 cursor-pointer border border-teal-200">
        <RefreshCw size={16} />
        New Session
      </button>
    </div>
  </div>

  <div class="p-6 space-y-8 print:p-2 print:space-y-0">
    <section class="print:break-inside-avoid">
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-slate-800 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">1 | Welcome + Rules + Today We Do</h3>
        <span class="text-sm font-semibold text-slate-700 bg-slate-100 border border-slate-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">5 min</span>
      </div>
      <div id="section-intro" class="grid grid-cols-1 gap-3 print:gap-1">
        {[1, 2].map(() => (
          <div class="border-2 border-slate-200 rounded-lg bg-white p-4 animate-pulse print:p-2 print:border">
            <div class="h-3 w-28 bg-slate-200 rounded mb-2"></div>
            <div class="h-3 w-11/12 bg-slate-100 rounded"></div>
          </div>
        ))}
      </div>
      <div class="mt-4 grid grid-cols-1 gap-4 print:gap-2">
        <div class="border-2 border-cyan-200 rounded-xl p-5 bg-cyan-50/50 print:p-2">
          <div class="text-xs font-bold uppercase tracking-widest text-cyan-800 mb-3 print:text-[9px] print:mb-1">Today We Do</div>
          <ol class="m-0 pl-5 space-y-2 text-sm text-slate-700 print:text-[10px] print:space-y-1">
            <li>Welcome together, hear the plan, and set the focus.</li>
            <li>Theola runs a short playful opener so everybody joins in.</li>
            <li>Warm up and stretch to get ready for paddling and standing.</li>
            <li>Learn one simple surf idea on the sand.</li>
            <li>Take that same idea into the water for focused practice.</li>
            <li>Finish with a quick debrief, clean-up, and goodbye.</li>
          </ol>
        </div>
        <div class="border-2 border-slate-200 rounded-xl p-5 bg-slate-50/70 print:p-2">
          <div class="text-xs font-bold uppercase tracking-widest text-slate-700 mb-3 print:text-[9px] print:mb-1">Ground Rules</div>
          <ol class="m-0 pl-5 space-y-2 text-sm text-slate-700 print:text-[10px] print:space-y-1">
            <li>We arrive together, greet the coaches, and listen for the start.</li>
            <li>We stay with the group on the sand and in the water.</li>
            <li>We wait for coach instructions before entering the water.</li>
            <li>We speak with respect and save feedback for the debrief.</li>
            <li>We take care of our boards, the beach, and each other.</li>
            <li>We finish properly: boards back, beach tidy, goodbye said.</li>
          </ol>
        </div>
      </div>
    </section>

    <section class="print:break-inside-avoid">
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-rose-700 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">2 | Theola Playful Opener</h3>
        <span class="text-sm font-semibold text-rose-700 bg-rose-50 border border-rose-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">10 min</span>
      </div>
      <div id="section-icebreaker" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-2 print:border">
          <div class="h-3 w-24 bg-rose-100 rounded mb-2"></div>
          <div class="h-4 w-44 bg-slate-200 rounded mb-2"></div>
          <div class="h-3 w-3/4 bg-slate-100 rounded"></div>
        </div>
      </div>
      <div id="section-icebreaker-note" class="mt-3 print:mt-1">
        <div class="border-2 border-rose-200 rounded-lg bg-rose-50/70 p-4 animate-pulse print:p-2">
          <div class="h-3 w-24 bg-rose-100 rounded mb-2"></div>
          <div class="h-3 w-4/5 bg-rose-50 rounded"></div>
        </div>
      </div>
    </section>

    <section class="print:break-inside-avoid">
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-amber-700 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">3 | Warmup + Stretch</h3>
        <span class="text-sm font-semibold text-amber-700 bg-amber-50 border border-amber-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">10 min</span>
        <span class="text-xs font-semibold text-purple-700 bg-purple-50 border border-purple-200 px-2 py-0.5 rounded-full print:text-[8px] print:px-1">● mobility</span>
        <span class="text-xs font-semibold text-orange-700 bg-orange-50 border border-orange-200 px-2 py-0.5 rounded-full print:text-[8px] print:px-1">● strength</span>
      </div>
      <div id="section-warmup" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="loading-skeleton space-y-3 print:space-y-1">
          {[1, 2, 3, 4].map(() => (
            <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-1.5 print:border">
              <div class="h-4 w-40 bg-slate-200 rounded mb-2"></div>
              <div class="h-3 w-3/4 bg-slate-100 rounded"></div>
            </div>
          ))}
        </div>
      </div>
      <div id="section-warmup-note" class="mt-3 print:mt-1">
        <div class="border-2 border-amber-200 rounded-lg bg-amber-50/70 p-4 animate-pulse print:p-2">
          <div class="h-3 w-24 bg-amber-100 rounded mb-2"></div>
          <div class="h-3 w-4/5 bg-amber-50 rounded"></div>
        </div>
      </div>
      <div class="mt-4 print:hidden">
        <div class="border border-slate-200 rounded-lg bg-slate-50/50 px-4 py-4">
          <div class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-3">Coach Video References</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <div class="text-xs font-semibold text-purple-700 mb-1.5">Rapture Camps — Flexibility</div>
              <div class="relative w-full overflow-hidden rounded-lg" style="padding-bottom:56.25%">
                <iframe src="https://www.facebook.com/plugins/video.php?href=https%3A%2F%2Fwww.facebook.com%2FRapturecamps%2Fvideos%2F1439071064290953%2F&show_text=false&width=560" class="absolute inset-0 w-full h-full border-0 rounded-lg" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" allowfullscreen></iframe>
              </div>
            </div>
            <div>
              <div class="text-xs font-semibold text-purple-700 mb-1.5">Red Bull — Mobility</div>
              <div class="relative w-full overflow-hidden rounded-lg" style="padding-bottom:56.25%">
                <iframe src="https://www.tiktok.com/embed/v2/7529540352924060950" class="absolute inset-0 w-full h-full border-0 rounded-lg" allow="encrypted-media" allowfullscreen></iframe>
              </div>
            </div>
            <div>
              <div class="text-xs font-semibold text-orange-700 mb-1.5">Instagram — Strength 1</div>
              <div class="relative w-full overflow-hidden rounded-lg" style="padding-bottom:56.25%">
                <iframe src="https://www.instagram.com/reel/C0325b5yTKS/embed/" class="absolute inset-0 w-full h-full border-0 rounded-lg" allow="encrypted-media" allowfullscreen></iframe>
              </div>
            </div>
            <div>
              <div class="text-xs font-semibold text-orange-700 mb-1.5">Instagram — Strength 2</div>
              <div class="relative w-full overflow-hidden rounded-lg" style="padding-bottom:56.25%">
                <iframe src="https://www.instagram.com/reel/DQcm4DsEhuA/embed/" class="absolute inset-0 w-full h-full border-0 rounded-lg" allow="encrypted-media" allowfullscreen></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="print:break-inside-avoid">
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-sky-800 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">4 | Theory on the Sand</h3>
        <span class="text-sm font-semibold text-sky-700 bg-sky-50 border border-sky-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">10 min</span>
      </div>
      <div id="section-theory" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-2 print:border">
          <div class="h-3 w-20 bg-sky-100 rounded mb-2"></div>
          <div class="h-4 w-48 bg-slate-200 rounded mb-2"></div>
          <div class="h-3 w-5/6 bg-slate-100 rounded mb-3"></div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[1, 2].map(() => (
              <div class="h-16 rounded-lg bg-slate-100"></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="print:break-inside-avoid">
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 id="water-block-heading" class="text-xl font-bold uppercase tracking-widest text-white bg-indigo-700 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">5 | Water Block: One Focus</h3>
        <span class="text-sm font-semibold text-indigo-700 bg-indigo-50 border border-indigo-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">20-60 min</span>
      </div>
      <div id="section-water-block" class="grid grid-cols-1 gap-3 print:gap-1">
        <div class="border-2 border-slate-200 rounded-lg p-4 animate-pulse print:p-2 print:border">
          <div class="h-3 w-28 bg-indigo-100 rounded mb-2"></div>
          <div class="h-4 w-52 bg-slate-200 rounded mb-3"></div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {[1, 2, 3].map(() => (
              <div class="h-20 rounded-lg bg-slate-100"></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="print:break-inside-avoid">
      <div class="flex items-center gap-3 mb-4 print:mb-1">
        <h3 class="text-xl font-bold uppercase tracking-widest text-white bg-emerald-700 px-4 py-1.5 rounded inline-block m-0 print:text-[13px] print:px-2.5 print:py-0.5">6 | Quick Debrief + Goodbye</h3>
        <span class="text-sm font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-3 py-1 rounded-full print:text-[9px] print:px-1.5 print:py-0">5 min</span>
      </div>
      <div id="section-closing" class="grid grid-cols-1 sm:grid-cols-2 gap-3 print:gap-1">
        {[1, 2].map(() => (
          <div class="border-2 border-slate-200 rounded-lg bg-white p-4 animate-pulse print:p-2 print:border">
            <div class="h-3 w-28 bg-emerald-100 rounded mb-2"></div>
            <div class="h-3 w-11/12 bg-slate-100 rounded"></div>
          </div>
        ))}
      </div>
    </section>
  </div>
</div>

<template id="tpl-activity-row">
  <div class="border-2 border-slate-200 rounded-lg p-4 bg-white print:p-1.5 print:border">
    <div class="flex items-start gap-3">
      <div class="mt-1.5 h-3 w-3 rounded-full shrink-0" data-slot="marker"></div>
      <div>
        <div class="text-lg font-semibold text-slate-700 print:text-sm" data-slot="name"></div>
        <div class="text-sm text-slate-500 font-medium print:text-[10px]" data-slot="description"></div>
      </div>
    </div>
  </div>
</template>

<template id="tpl-single-card">
  <div class="border-2 rounded-xl p-5 bg-white print:p-2">
    <div class="text-xs font-bold uppercase tracking-widest mb-2 print:text-[9px]" data-slot="label"></div>
    <div class="text-xl font-bold text-slate-800 mb-2 print:text-[12px]" data-slot="name"></div>
    <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="description"></p>
  </div>
</template>

<template id="tpl-note-card">
  <div class="border-2 rounded-lg p-4 bg-white print:p-2">
    <div class="text-xs font-bold uppercase tracking-widest mb-2 print:text-[9px]" data-slot="label"></div>
    <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="text"></p>
  </div>
</template>

<template id="tpl-theory-card">
  <div class="border-2 border-sky-200 rounded-xl p-5 bg-sky-50/40 print:p-2">
    <div class="text-xs font-bold uppercase tracking-widest text-sky-800 mb-2 print:text-[9px]">Today’s Topic</div>
    <div class="text-xl font-bold text-slate-900 mb-2 print:text-[12px]" data-slot="topic"></div>
    <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="explain"></p>
    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3 print:mt-2 print:gap-1">
      <div class="border border-sky-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-sky-800 mb-2 print:text-[9px]">Coach Demo</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="demoCue"></p>
      </div>
      <div class="border border-sky-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-sky-800 mb-2 print:text-[9px]">Check Question</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="checkQuestion"></p>
      </div>
    </div>
  </div>
</template>

<template id="tpl-water-focus-card">
  <div class="border-2 border-indigo-200 rounded-xl p-5 bg-indigo-50/40 print:p-2">
    <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-2 print:text-[9px]">Today’s Water Focus</div>
    <div class="text-xl font-bold text-slate-900 mb-3 print:text-[12px]" data-slot="focus"></div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 print:gap-1">
      <div class="border border-indigo-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-2 print:text-[9px]">Coach Cue</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="coachCue"></p>
      </div>
      <div class="border border-indigo-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-2 print:text-[9px]">What Good Looks Like</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="successMarker"></p>
      </div>
      <div class="border border-indigo-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-2 print:text-[9px]">Session Challenge</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="challenge"></p>
      </div>
    </div>
  </div>
</template>

<template id="tpl-water-drills-card">
  <div class="border-2 border-indigo-200 rounded-xl p-5 bg-indigo-50/40 print:p-2">
    <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-3 print:text-[9px]">Flat Day Water Drills</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 print:gap-1" data-slot="drills-grid"></div>
    <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3 print:mt-2 print:gap-1">
      <div class="border border-indigo-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-2 print:text-[9px]">Coach Note</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="coachNote"></p>
      </div>
      <div class="border border-indigo-200 rounded-lg bg-white p-4 print:p-2">
        <div class="text-xs font-bold uppercase tracking-widest text-indigo-800 mb-2 print:text-[9px]">Session Challenge</div>
        <p class="text-sm text-slate-700 leading-snug m-0 print:text-[10px]" data-slot="sessionChallenge"></p>
      </div>
    </div>
  </div>
</template>

<template id="tpl-water-drill-item">
  <div class="border border-indigo-200 rounded-lg bg-white p-3 print:p-1.5">
    <div class="flex items-start gap-2">
      <span class="text-[10px] font-bold uppercase tracking-wider text-indigo-600 bg-indigo-100 px-1.5 py-0.5 rounded mt-0.5 shrink-0 print:text-[7px]" data-slot="category"></span>
      <div>
        <div class="text-sm font-semibold text-slate-700 print:text-[10px]" data-slot="name"></div>
        <div class="text-xs text-slate-500 mt-0.5 print:text-[9px]" data-slot="description"></div>
        <div class="text-[10px] text-amber-700 font-medium mt-1 print:text-[8px] hidden" data-slot="safetyNote"></div>
      </div>
    </div>
  </div>
</template>

<script>
  interface ActivityItem {
    name: string;
    description: string;
  }

  interface WaterDrillItem {
    name: string;
    description: string;
    category: string;
    safetyNote?: string;
  }

  interface WavyWaterBlock {
    mode: "wavy";
    focus: string;
    coachCue: string;
    successMarker: string;
    challenge: string;
  }

  interface FlatWaterBlock {
    mode: "flat";
    drills: WaterDrillItem[];
    coachNote: string;
    sessionChallenge: string;
  }

  interface SurfSessionData {
    intro: {
      sessionGoal: string;
      structureNote: string;
    };
    icebreaker: {
      name: string;
      description: string;
      coachNote: string;
    };
    warmup: {
      drills: ActivityItem[];
      coachNote: string;
    };
    theory: {
      topic: string;
      explain: string;
      demoCue: string;
      checkQuestion: string;
    };
    waterBlock: WavyWaterBlock | FlatWaterBlock;
    closing: {
      debriefPrompt: string;
      goodbyeCue: string;
    };
  }

  let currentMode: "wavy" | "flat" = "wavy";

  const FALLBACK_DATA: SurfSessionData = {
    intro: {
      sessionGoal:
        "Today we build confidence with calm habits, clear coaching, and one simple surf skill.",
      structureNote:
        "We start together on the sand, learn one idea, then take that same idea into the water.",
    },
    icebreaker: {
      name: "Name & Wave Move",
      description:
        "In a circle, each surfer says their name and shows one funny surf move for the group to copy.",
      coachNote:
        "Theola sets the tone: smiles first, quick turns, and make sure every child is seen.",
    },
    warmup: {
      drills: [
        {
          name: "Hip Circles",
          description:
            "Stand on one leg, draw big circles with the other knee to loosen hips — five each direction.",
        },
        {
          name: "Cat-Cow Flow",
          description:
            "On all fours, arch the back up like a cat then drop the belly like a cow, slow and smooth.",
        },
        {
          name: "Pop-Up Push-Ups",
          description:
            "Start flat on the sand, push up and spring to surf stance, then back down — five reps.",
        },
        {
          name: "Superhero Hold",
          description:
            "Lie face down, lift arms and legs off the sand and hold for five seconds, then relax.",
        },
      ],
      coachNote:
        "Keep the tempo light and tidy; this block prepares bodies for surfing, not exhaustion.",
    },
    theory: {
      topic: "paddling body position",
      explain:
        "When your chest is lifted and your body is centered, the board glides straighter and catches waves earlier.",
      demoCue:
        "Show one bad paddle position and one good one, then let the kids spot the difference.",
      checkQuestion:
        "Where should your chest and eyes be when you paddle for a wave?",
    },
    waterBlock: {
      mode: "wavy" as const,
      focus: "paddling body position",
      coachCue:
        "Long body, light chest lift, and eyes forward before every wave.",
      successMarker:
        "Good looks like a straight board, steady paddling, and an earlier, calmer takeoff.",
      challenge:
        "Each surfer finds 3 waves where they set their body position before trying to stand.",
    },
    closing: {
      debriefPrompt:
        "What helped you most today when you went from sand to water?",
      goodbyeCue:
        "Shake hands, thank the group, and carry boards back together.",
    },
  };

  const FALLBACK_FLAT_WATER_BLOCK: FlatWaterBlock = {
    mode: "flat",
    drills: [
      { name: "Paddle Sprint Relay", description: "Teams of two, paddle to a marker and back, tag your partner.", category: "paddle" },
      { name: "Board Spin", description: "Sitting on board, use hands to spin 360 degrees both directions.", category: "board-control" },
      { name: "Seal Dive", description: "Push face and body underwater, pop back up smiling — repeat five times.", category: "water-confidence", safetyNote: "Waist-deep water only, coach in water." },
      { name: "Shark Tag", description: "One 'shark' swims to tag others, tagged surfers join the shark team.", category: "swimming" },
    ],
    coachNote: "Focus on calm, controlled movements — flat days are perfect for practising skills without pressure.",
    sessionChallenge: "Each surfer completes all four water drills and picks their favourite to show the group.",
  };

  async function fetchJSON<T>(url: string, timeoutMs = 35_000): Promise<T> {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), timeoutMs);
    try {
      const res = await fetch(url, { signal: controller.signal });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      return await res.json();
    } finally {
      clearTimeout(id);
    }
  }

  function withLoading(btn: HTMLButtonElement, action: () => Promise<void>) {
    return async () => {
      btn.disabled = true;
      const originalHtml = btn.innerHTML;
      btn.innerHTML =
        '<span class="inline-block w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span> Loading...';
      try {
        await action();
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalHtml;
      }
    };
  }

  function cloneTemplate(id: string): DocumentFragment {
    const tpl = document.getElementById(id) as HTMLTemplateElement;
    return tpl.content.cloneNode(true) as DocumentFragment;
  }

  function fillSlots(fragment: DocumentFragment, data: Record<string, string>): void {
    for (const [key, value] of Object.entries(data)) {
      const el = fragment.querySelector(`[data-slot="${key}"]`);
      if (el) el.textContent = value;
    }
  }

  function addClasses(el: Element | null, classes: string): void {
    if (!el) return;
    for (const cls of classes.split(" ")) {
      if (cls) el.classList.add(cls);
    }
  }

  function renderNoteCard(
    label: string,
    text: string,
    wrapperClasses: string,
    labelClasses: string,
  ): DocumentFragment {
    const frag = cloneTemplate("tpl-note-card");
    fillSlots(frag, { label, text });
    addClasses(frag.querySelector("div"), wrapperClasses);
    addClasses(frag.querySelector('[data-slot="label"]'), labelClasses);
    return frag;
  }

  function renderIntroBlock(container: HTMLElement, data: SurfSessionData["intro"]): void {
    container.innerHTML = "";
    container.appendChild(
      renderNoteCard(
        "Session Goal",
        data.sessionGoal,
        "border-cyan-200 bg-cyan-50/70",
        "text-cyan-800",
      ),
    );
    container.appendChild(
      renderNoteCard(
        "Structure Note",
        data.structureNote,
        "border-teal-200 bg-teal-50/70",
        "text-teal-800",
      ),
    );
  }

  function renderSingleCard(
    container: HTMLElement,
    label: string,
    name: string,
    description: string,
    wrapperClasses: string,
    labelClasses: string,
  ): void {
    container.innerHTML = "";
    const frag = cloneTemplate("tpl-single-card");
    fillSlots(frag, { label, name, description });
    addClasses(frag.querySelector("div"), wrapperClasses);
    addClasses(frag.querySelector('[data-slot="label"]'), labelClasses);
    container.appendChild(frag);
  }

  function renderActivityList(
    container: HTMLElement,
    activities: ActivityItem[],
    markerClasses: string,
    perItemMarkers?: string[],
  ): void {
    container.innerHTML = "";
    activities.forEach((activity, index) => {
      const frag = cloneTemplate("tpl-activity-row");
      fillSlots(frag, {
        name: activity.name,
        description: activity.description,
      });
      const marker = perItemMarkers?.[index] ?? markerClasses;
      addClasses(frag.querySelector('[data-slot="marker"]'), marker);
      container.appendChild(frag);
    });
  }

  function renderTheoryBlock(container: HTMLElement, data: SurfSessionData["theory"]): void {
    container.innerHTML = "";
    const frag = cloneTemplate("tpl-theory-card");
    fillSlots(frag, {
      topic: data.topic,
      explain: data.explain,
      demoCue: data.demoCue,
      checkQuestion: data.checkQuestion,
    });
    container.appendChild(frag);
  }

  function renderWavyWaterBlock(container: HTMLElement, data: WavyWaterBlock): void {
    container.innerHTML = "";
    const frag = cloneTemplate("tpl-water-focus-card");
    fillSlots(frag, {
      focus: data.focus,
      coachCue: data.coachCue,
      successMarker: data.successMarker,
      challenge: data.challenge,
    });
    container.appendChild(frag);
  }

  function renderFlatWaterBlock(container: HTMLElement, data: FlatWaterBlock): void {
    container.innerHTML = "";
    const frag = cloneTemplate("tpl-water-drills-card");
    const grid = frag.querySelector('[data-slot="drills-grid"]');
    if (grid) {
      for (const drill of data.drills) {
        const item = cloneTemplate("tpl-water-drill-item");
        fillSlots(item, {
          category: drill.category,
          name: drill.name,
          description: drill.description,
        });
        if (drill.safetyNote) {
          const noteEl = item.querySelector('[data-slot="safetyNote"]');
          if (noteEl) {
            noteEl.textContent = drill.safetyNote;
            noteEl.classList.remove("hidden");
          }
        }
        grid.appendChild(item);
      }
    }
    fillSlots(frag, {
      coachNote: data.coachNote,
      sessionChallenge: data.sessionChallenge,
    });
    container.appendChild(frag);
  }

  function renderWaterBlock(container: HTMLElement, data: SurfSessionData["waterBlock"]): void {
    if (data.mode === "flat") {
      renderFlatWaterBlock(container, data);
    } else {
      renderWavyWaterBlock(container, data);
    }
  }

  function renderClosingBlock(container: HTMLElement, data: SurfSessionData["closing"]): void {
    container.innerHTML = "";
    container.appendChild(
      renderNoteCard(
        "Debrief Prompt",
        data.debriefPrompt,
        "border-emerald-200 bg-emerald-50/70",
        "text-emerald-800",
      ),
    );
    container.appendChild(
      renderNoteCard(
        "Goodbye Cue",
        data.goodbyeCue,
        "border-green-200 bg-green-50/70",
        "text-green-800",
      ),
    );
  }

  async function loadAll(): Promise<void> {
    const ids = {
      intro: document.getElementById("section-intro"),
      icebreaker: document.getElementById("section-icebreaker"),
      icebreakerNote: document.getElementById("section-icebreaker-note"),
      warmup: document.getElementById("section-warmup"),
      warmupNote: document.getElementById("section-warmup-note"),
      theory: document.getElementById("section-theory"),
      waterBlock: document.getElementById("section-water-block"),
      closing: document.getElementById("section-closing"),
    };

    let data: SurfSessionData;

    try {
      data = await fetchJSON<SurfSessionData>(`/api/generate-surf-exercises?mode=${currentMode}`);
    } catch (error) {
      console.error("Failed to load surf session, using fallback:", error);
      data = FALLBACK_DATA;
    }

    const intro =
      data.intro?.sessionGoal && data.intro?.structureNote
        ? data.intro
        : FALLBACK_DATA.intro;
    const icebreaker =
      data.icebreaker?.name &&
      data.icebreaker?.description &&
      data.icebreaker?.coachNote
        ? data.icebreaker
        : FALLBACK_DATA.icebreaker;
    const warmup =
      data.warmup?.drills?.length === 4 && data.warmup?.coachNote
        ? data.warmup
        : FALLBACK_DATA.warmup;
    const theory =
      data.theory?.topic &&
      data.theory?.explain &&
      data.theory?.demoCue &&
      data.theory?.checkQuestion
        ? data.theory
        : FALLBACK_DATA.theory;
    let waterBlock: SurfSessionData["waterBlock"];
    const wb = data.waterBlock;
    if (wb?.mode === "flat") {
      waterBlock =
        wb.drills?.length >= 1 && wb.coachNote && wb.sessionChallenge
          ? wb
          : FALLBACK_FLAT_WATER_BLOCK;
    } else {
      waterBlock =
        wb?.mode === "wavy" && wb.focus && wb.coachCue && wb.successMarker && wb.challenge
          ? wb
          : FALLBACK_DATA.waterBlock;
    }
    const closing =
      data.closing?.debriefPrompt && data.closing?.goodbyeCue
        ? data.closing
        : FALLBACK_DATA.closing;

    if (ids.intro) renderIntroBlock(ids.intro, intro);
    if (ids.icebreaker) {
      renderSingleCard(
        ids.icebreaker,
        "Opener",
        icebreaker.name,
        icebreaker.description,
        "border-rose-200 bg-rose-50/50",
        "text-rose-800",
      );
    }
    if (ids.icebreakerNote) {
      ids.icebreakerNote.innerHTML = "";
      ids.icebreakerNote.appendChild(
        renderNoteCard(
          "Coach Note",
          icebreaker.coachNote,
          "border-rose-200 bg-rose-50/70",
          "text-rose-800",
        ),
      );
    }
    if (ids.warmup) {
      renderActivityList(ids.warmup, warmup.drills, "bg-amber-500", [
        "bg-purple-500",
        "bg-purple-500",
        "bg-orange-500",
        "bg-orange-500",
      ]);
    }
    if (ids.warmupNote) {
      ids.warmupNote.innerHTML = "";
      ids.warmupNote.appendChild(
        renderNoteCard(
          "Coach Note",
          warmup.coachNote,
          "border-amber-200 bg-amber-50/70",
          "text-amber-800",
        ),
      );
    }
    if (ids.theory) renderTheoryBlock(ids.theory, theory);
    if (ids.waterBlock) renderWaterBlock(ids.waterBlock, waterBlock);
    const waterHeading = document.getElementById("water-block-heading");
    if (waterHeading) {
      waterHeading.textContent =
        currentMode === "flat" ? "5 | Water Drills: Flat Day" : "5 | Water Block: One Focus";
    }
    if (ids.closing) renderClosingBlock(ids.closing, closing);
  }

  const dateEl = document.getElementById("session-date");
  if (dateEl) {
    const d = new Date();
    dateEl.textContent = d.toLocaleDateString("en-GB", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
    });
  }

  const regenBtn = document.getElementById("regen-all-btn") as HTMLButtonElement;
  if (regenBtn) {
    regenBtn.disabled = true;
    regenBtn.addEventListener("click", withLoading(regenBtn, loadAll));
  }

  const modeToggle = document.getElementById("mode-toggle") as HTMLButtonElement;
  const toggleLabelWavy = document.getElementById("toggle-label-wavy");
  const toggleLabelFlat = document.getElementById("toggle-label-flat");
  if (modeToggle) {
    modeToggle.addEventListener("click", () => {
      currentMode = currentMode === "wavy" ? "flat" : "wavy";
      const thumb = modeToggle.querySelector("span") as HTMLElement;
      if (currentMode === "flat") {
        modeToggle.classList.replace("bg-cyan-500", "bg-amber-500");
        thumb.style.transform = "translateX(1.25rem)";
        modeToggle.setAttribute("aria-checked", "true");
        if (toggleLabelFlat) toggleLabelFlat.classList.replace("text-slate-400", "text-amber-700");
        if (toggleLabelWavy) toggleLabelWavy.classList.replace("text-cyan-700", "text-slate-400");
      } else {
        modeToggle.classList.replace("bg-amber-500", "bg-cyan-500");
        thumb.style.transform = "translateX(0)";
        modeToggle.setAttribute("aria-checked", "false");
        if (toggleLabelWavy) toggleLabelWavy.classList.replace("text-slate-400", "text-cyan-700");
        if (toggleLabelFlat) toggleLabelFlat.classList.replace("text-amber-700", "text-slate-400");
      }
      if (regenBtn) regenBtn.disabled = true;
      loadAll().then(() => {
        if (regenBtn) regenBtn.disabled = false;
      });
    });
  }

  const generatedSections = [
    document.getElementById("section-intro"),
    document.getElementById("section-icebreaker"),
    document.getElementById("section-icebreaker-note"),
    document.getElementById("section-warmup"),
    document.getElementById("section-warmup-note"),
    document.getElementById("section-theory"),
    document.getElementById("section-water-block"),
    document.getElementById("section-closing"),
  ];

  const shouldLoadAll = generatedSections.some((section) =>
    !section || Boolean(section.querySelector(".loading-skeleton, .animate-pulse")),
  );

  if (shouldLoadAll) {
    loadAll().then(() => {
      if (regenBtn) regenBtn.disabled = false;
    });
  } else if (regenBtn) {
    regenBtn.disabled = false;
  }

  const printBtn = document.getElementById("print-btn");
  if (printBtn) {
    printBtn.addEventListener("click", () => {
      const header = document.querySelector("body > div > header") as HTMLElement;
      const footer = document.querySelector("body > div > footer") as HTMLElement;
      const main = document.querySelector("body > div > main") as HTMLElement;
      const proseEls = document.querySelectorAll<HTMLElement>(
        ".prose > *:not(.worksheet-container)",
      );

      if (header) header.style.display = "none";
      if (footer) footer.style.display = "none";
      if (main) {
        main.style.width = "100%";
        main.style.maxWidth = "100%";
        main.style.padding = "0";
        main.style.margin = "0";
      }
      proseEls.forEach((el) => (el.style.display = "none"));
      document.body.style.background = "white";

      let restored = false;
      const restoreLayout = () => {
        if (restored) return;
        restored = true;
        if (header) header.style.display = "";
        if (footer) footer.style.display = "";
        if (main) {
          main.style.width = "";
          main.style.maxWidth = "";
          main.style.padding = "";
          main.style.margin = "";
        }
        proseEls.forEach((el) => (el.style.display = ""));
        document.body.style.background = "";
      };

      window.addEventListener("afterprint", restoreLayout, { once: true });
      window.print();
      if (!("onafterprint" in window)) {
        setTimeout(restoreLayout, 1200);
      }
    });
  }
</script>
