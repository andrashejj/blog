---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images: ImageItem[];
  columns?: 2 | 3;
}

const { images, columns = 2 } = Astro.props;

const gridClass = columns === 3
  ? "grid-cols-1 sm:grid-cols-3"
  : "grid-cols-1 sm:grid-cols-2";
---

<div class={`not-prose grid ${gridClass} gap-4 my-8`}>
  {images.map(({ src, alt }) => (
    <figure>
      <img
        src={src}
        alt={alt}
        class="w-full rounded-2xl border border-gray-200 shadow-md"
        loading="lazy"
      />
      {alt && (
        <figcaption class="mt-2 text-xs text-gray-400 italic text-center">{alt}</figcaption>
      )}
    </figure>
  ))}
</div>
